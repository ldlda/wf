{
  "store_root": ".wf_mcp_store",
  "connections": [
    {
      "id": "context7.default",
      "server": "context7",
      "account": "default",
      "enabled": true,
      "metadata": {
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@upstash/context7-mcp"],
        "env": {}
      }
    },
    {
      "id": "playwright.default",
      "server": "playwright",
      "account": "default",
      "enabled": true,
      "metadata": {
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@playwright/mcp@latest"],
        "env": {}
      }
    },
    {
      "id": "everything.default",
      "server": "everything",
      "account": "demo",
      "enabled": true,
      "metadata": {
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-everything"],
        "env": {}
      }
    },
    {
      "id": "serena.default",
      "server": "serena",
      "account": "default",
      "enabled": true,
      "metadata": {
        "transport": "stdio",
        "command": "serena",
        "args": ["start-mcp-server", "--project-from-cwd"],
        "env": {}
      }
    }
  ]
}
