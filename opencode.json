{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "python": {
      "command": ["uv", "run", "basedpyright-langserver", "--stdio"],
      "extensions": [".py"]
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["serena", "start-mcp-server", "--project-from-cwd"],
    }
  }
}